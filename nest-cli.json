{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "**/*.lua",
        "outDir": "dist"
      },
      {
        "include": "**/*.hbs",
        "outDir": "dist"
      }
    ]
  },
  "generateOptions": {
    "spec": false,
    "module": "modules"
  }
}
